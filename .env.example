# Canopus environment. Copy to `.env` and change every secret before any
# real deployment.
#
#   cp .env.example .env

COMPOSE_PROJECT_NAME=canopus
PYTHONUNBUFFERED=1

# Use the baked production config only (no dev pythonpath, no hot reload).
DEV_MODE=false
PYTHONPATH=/app/pythonpath
BUILD_SUPERSET_FRONTEND_IN_DOCKER=true

# --- Superset runtime ---
SUPERSET_ENV=production
SUPERSET_APP_ROOT=/
SUPERSET_LOG_LEVEL=info
SUPERSET_PORT=8088
# Load the bundled example dashboards/datasets (used to demo the start page).
# Set to "no" for a clean instance.
SUPERSET_LOAD_EXAMPLES=yes

# Start page (welcome) dashboard. Leave blank to auto-pick the first published
# dashboard; set a dashboard slug to pin a specific one.
CANOPUS_WELCOME_DASHBOARD_SLUG=

# CHANGE ME - generate with: openssl rand -base64 42
SUPERSET_SECRET_KEY=change_me_to_a_long_random_value

# Admin bootstrap user (created by superset-init)
ADMIN_PASSWORD=admin

# --- Metadata database (postgres) ---
DATABASE_DIALECT=postgresql
DATABASE_DB=superset
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USER=superset
# CHANGE ME
DATABASE_PASSWORD=superset
POSTGRES_DB=superset
POSTGRES_USER=superset
# CHANGE ME
POSTGRES_PASSWORD=superset

# --- Examples database (same postgres server) ---
EXAMPLES_DB=examples
EXAMPLES_HOST=db
EXAMPLES_PORT=5432
EXAMPLES_USER=examples
# CHANGE ME
EXAMPLES_PASSWORD=examples

# --- Redis (cache + Celery broker/results) ---
REDIS_HOST=redis
REDIS_PORT=6379
